        <!-- Вывод по FWHT -->
        <mxCell id="fwht_summary_title" value="🏆 Почему FWHT может быть лучшим выбором?" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#0d652d" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="500" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="fwht_summary_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="630" height="180" as="geometry" />
        </mxCell>
        
        <mxCell id="fwht_summary_text" value="⚡ ВЫЧИСЛИТЕЛЬНАЯ ЭФФЕКТИВНОСТЬ:&#xa;   • Только сложение и вычитание — нет умножений!&#xa;   • Идеально для встраиваемых систем, микроконтроллеров&#xa;   • O(N log N) — та же сложность, но проще операции&#xa;&#xa;📊 БАЛАНС КАЧЕСТВО/СКОРОСТЬ:&#xa;   • Качество сопоставимо с FFT при правильном отборе коэффициентов&#xa;   • Быстрее на системах без FPU (арифметический сопроцессор)&#xa;&#xa;🔧 ГИБКОСТЬ:&#xa;   • Поддержка режимов energy/lowpass для оптимизации&#xa;   • Возможность адаптации sequency-порядка под задачу" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="50" y="435" width="610" height="170" as="geometry" />
        </mxCell>
        
        <!-- Рекомендации -->
        <mxCell id="rec_title" value="📋 Рекомендации по выбору метода" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="630" width="400" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="rec_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="660" width="630" height="180" as="geometry" />
        </mxCell>
        
        <mxCell id="rec_text" value="🎯 Стандартный MP3 — если нужна максимальная совместимость&#xa;&#xa;⚡ FWHT — если важна скорость и ограниченные ресурсы&#xa;   (встраиваемые системы, реальтайм обработка)&#xa;&#xa;📊 FFT — если нужен частотный анализ и спектральные данные&#xa;&#xa;🏆 DCT — если нужна максимальная концентрация энергии&#xa;   (стандарт индустрии для сжатия)&#xa;&#xa;🔢 DWT — если важен анализ переходных процессов&#xa;   (ударные инструменты, скачки сигнала)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="50" y="665" width="610" height="170" as="geometry" />
        </mxCell>
        
