        <mxCell id="energy_label" value="Энергия в низких частотах →" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="140" y="710" width="200" height="20" as="geometry" />
