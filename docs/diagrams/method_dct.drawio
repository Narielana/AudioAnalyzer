<mxfile host="app.diagrams.net" modified="2025-03-11T00:00:00.000Z" agent="Draw.io" version="22.1.0" type="device">
  <diagram id="dct-method" name="DCT - Косинусное преобразование">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Заголовок -->
        <mxCell id="title" value="DCT (Discrete Cosine Transform)&#xa;Дискретное косинусное преобразование" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="700" height="50" as="geometry" />
        </mxCell>
        
        <!-- Секция: Идея метода -->
        <mxCell id="idea_title" value="💡 Идея метода (простыми словами)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="idea_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="500" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="idea_text" value="DCT — это &quot;половина&quot; преобразования Фурье:&#xa;&#xa;• Использует только косинусы (не синусы)&#xa;• Базис симметричный относительно нуля&#xa;&#xa;Почему это важно:&#xa;• Хорошо концентрирует энергию в низких частотах&#xa;• Используется в JPEG, MP3, AAC — стандартах сжатия!&#xa;• Коэффициенты быстро убывают к нулю" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="50" y="105" width="480" height="120" as="geometry" />
        </mxCell>
        
        <!-- Схема работы -->
        <mxCell id="scheme_title" value="⚙️ Как работает DCT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="300" height="30" as="geometry" />
        </mxCell>
        
        <!-- Блоки -->
        <mxCell id="input" value="Входной&#xa;сигнал" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="80" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="window" value="Окно&#xa;Ханна" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="150" y="300" width="80" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="dct_core" value="DCT-II&#xa;(ортонорм.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="260" y="300" width="90" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="coeffs" value="Коэффициенты&#xa;(только веществ.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="380" y="295" width="100" height="60" as="geometry" />
        </mxCell>
        
        <mxCell id="selection" value="Отбор&#xa;(energy/lowpass)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="380" y="380" width="100" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="idct" value="IDCT-III&#xa;(обратное)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="260" y="380" width="90" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="output" value="Восстановленный&#xa;сигнал" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="150" y="380" width="80" height="50" as="geometry" />
        </mxCell>
        
        <mxCell id="mp3" value="MP3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="80" height="50" as="geometry" />
        </mxCell>
        
        <!-- Стрелки -->
        <mxCell id="arr1" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="input" target="window">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr2" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="window" target="dct_core">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr3" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="dct_core" target="coeffs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr4" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="coeffs" target="selection">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr5" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="selection" target="idct">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr6" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="idct" target="output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr7" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="output" target="mp3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Математика -->
        <mxCell id="math_title" value="📐 Математическая формула" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="math_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="500" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="math_text" value="X[k] = Σ x[n] · cos(π·k·(2n+1)/(2N)),  k = 0..N-1&#xa;&#xa;Особенность: все коэффициенты вещественные (не комплексные)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;spacingTop=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="495" width="480" height="70" as="geometry" />
        </mxCell>
        
        <!-- Преимущества -->
        <mxCell id="pros_title" value="✅ Преимущества DCT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#0d652d" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="pros_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="600" y="130" width="450" height="150" as="geometry" />
        </mxCell>
        
        <mxCell id="pros_text" value="📊 Концентрация энергии:&#xa;   • Большая энергия в первых коэффициентах&#xa;   • Идеально для сжатия с потерями&#xa;&#xa;🔧 Простота:&#xa;   • Только вещественные числа&#xa;   • Нет комплексной арифметики&#xa;&#xa;🏆 Стандарт индустрии:&#xa;   • Основа MP3, AAC, JPEG, MPEG&#xa;   • Проверен десятилетиями" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="610" y="135" width="430" height="140" as="geometry" />
        </mxCell>
        
        <!-- Недостатки -->
        <mxCell id="cons_title" value="⚠️ Недостатки DCT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="600" y="300" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="cons_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="600" y="330" width="450" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="cons_text" value="🔢 Блочная обработка:&#xa;   • Границы блоков могут создавать артефакты&#xa;   • Требует overlap-add для сглаживания&#xa;&#xa;💻 Вычисления:&#xa;   • Требует умножений (медленнее FWHT)&#xa;&#xa;📈 Спектральная утечка:&#xa;   • Как и FFT, требует окон" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="610" y="335" width="430" height="120" as="geometry" />
        </mxCell>
        
        <!-- Сравнение энергии -->
        <mxCell id="energy_title" value="📈 Распределение энергии DCT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="590" width="250" height="20" as="geometry" />
