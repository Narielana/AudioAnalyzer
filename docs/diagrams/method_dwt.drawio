  <diagram id="dwt-method" name="DWT - Вейвлет-преобразование">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Заголовок -->
        <mxCell id="title" value="DWT (Discrete Wavelet Transform)&#xa;Дискретное вейвлет-преобразование Хаара" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="150" y="10" width="800" height="50" as="geometry" />
        </mxCell>
        
        <!-- Секция: Идея метода -->
        <mxCell id="idea_title" value="💡 Идея метода (простыми словами)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="idea_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="500" height="140" as="geometry" />
        </mxCell>
        
        <mxCell id="idea_text" value="DWT анализирует сигнал на разных &quot;масштабах&quot;:&#xa;&#xa;• Как смотреть на картинку с разного расстояния&#xa;• Большие детали → маленькие детали&#xa;&#xa;Вейвлет Хаара — самый простой:&#xa;• Сравнивает соседние пары отсчётов&#xa;• A = среднее (сглаженное)&#xa;• D = разница (детали)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="50" y="105" width="480" height="130" as="geometry" />
        </mxCell>
        
        <!-- Схема декомпозиции -->
        <mxCell id="scheme_title" value="⚙️ Многоуровневая декомпозиция" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="260" width="300" height="30" as="geometry" />
        </mxCell>
        
        <!-- Уровень 0 -->
        <mxCell id="level0" value="Исходный сигнал (N отсчётов)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="180" height="40" as="geometry" />
        </mxCell>
        
        <!-- Стрелка вниз -->
        <mxCell id="arr0" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="340" as="sourcePoint" />
            <mxPoint x="130" y="370" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="arr0_label" value="DWT" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="140" y="345" width="40" height="20" as="geometry" />
        </mxCell>
        
        <!-- Уровень 1 -->
        <mxCell id="a1" value="A₁ (N/2)&#xa;аппроксимация" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="60" y="370" width="80" height="40" as="geometry" />
        </mxCell>
        <mxCell id="d1" value="D₁ (N/2)&#xa;детали" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="160" y="370" width="80" height="40" as="geometry" />
        </mxCell>
        
        <!-- Стрелка к D1 -->
        <mxCell id="arr1" style="endArrow=classic;html=1;strokeWidth=1;dashed=1" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="360" as="sourcePoint" />
            <mxPoint x="200" y="370" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <!-- Уровень 2 -->
        <mxCell id="arr2" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="410" as="sourcePoint" />
            <mxPoint x="100" y="440" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <mxCell id="a2" value="A₂ (N/4)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="60" y="440" width="60" height="35" as="geometry" />
        </mxCell>
        <mxCell id="d2" value="D₂ (N/4)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="140" y="440" width="60" height="35" as="geometry" />
        </mxCell>
        
        <!-- Уровень 3 -->
        <mxCell id="arr3" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="90" y="475" as="sourcePoint" />
            <mxPoint x="90" y="500" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        
        <mxCell id="a3" value="A₃ (N/8)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="60" y="500" width="55" height="30" as="geometry" />
        </mxCell>
        <mxCell id="d3" value="D₃ (N/8)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="130" y="500" width="55" height="30" as="geometry" />
        </mxCell>
        
        <!-- Легенда -->
        <mxCell id="legend_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="250" y="300" width="150" height="100" as="geometry" />
        </mxCell>
        <mxCell id="legend_title" value="Легенда:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="260" y="305" width="60" height="20" as="geometry" />
        </mxCell>
        <mxCell id="leg_a" value="A — аппроксимация&#xa;(низкие частоты)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="260" y="325" width="130" height="30" as="geometry" />
        </mxCell>
        <mxCell id="leg_d" value="D — детали&#xa;(высокие частоты)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="260" y="360" width="130" height="30" as="geometry" />
        </mxCell>
        
        <!-- Формулы -->
        <mxCell id="math_title" value="📐 Формулы вейвлета Хаара" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="math_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="40" y="590" width="350" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="math_text" value="Разложение:&#xa;  A[n] = (x[2n] + x[2n+1]) / √2   — сглаживание&#xa;  D[n] = (x[2n] - x[2n+1]) / √2   — детали&#xa;&#xa;Восстановление:&#xa;  x[2n]   = (A[n] + D[n]) / √2&#xa;  x[2n+1] = (A[n] - D[n]) / √2" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="595" width="330" height="90" as="geometry" />
        </mxCell>
        
        <!-- Преимущества -->
        <mxCell id="pros_title" value="✅ Преимущества DWT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#0d652d" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="pros_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="600" y="130" width="450" height="150" as="geometry" />
        </mxCell>
        
        <mxCell id="pros_text" value="🎯 Локализация во времени И частоте:&#xa;   • FFT теряет информацию о времени&#xa;   • DWT сохраняет оба измерения&#xa;&#xa;📊 Разные масштабы:&#xa;   • Анализирует и низкие, и высокие частоты&#xa;   • Подходит для переходных процессов&#xa;&#xa;⚡ Эффективность:&#xa;   • Хаар — самый быстрый вейвлет&#xa;   • Только сложения и вычитания" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="610" y="135" width="430" height="140" as="geometry" />
        </mxCell>
        
        <!-- Недостатки -->
        <mxCell id="cons_title" value="⚠️ Недостатки DWT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="600" y="300" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="cons_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="600" y="330" width="450" height="120" as="geometry" />
        </mxCell>
        
        <mxCell id="cons_text" value="🔲 Разрывность Хаара:&#xa;   • Прямоугольная форма — не гладкая&#xa;   • Хуже для плавных сигналов&#xa;&#xa;📊 Ограниченное частотное разрешение:&#xa;   • Зависит от уровня декомпозиции&#xa;&#xa;🔢 Фиксированный базис:&#xa;   • Нельзя адаптировать под сигнал" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="610" y="335" width="430" height="110" as="geometry" />
        </mxCell>
        
        <!-- Применение -->
        <mxCell id="use_title" value="🎯 Где применять DWT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="600" y="470" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="use_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="600" y="500" width="450" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="use_text" value="• Обнаружение переходов и скачков в сигнале&#xa;• Сжатие с сохранением структуры&#xa;• Анализ атак (ударные инструменты)&#xa;• Мультимасштабный анализ аудио" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="610" y="505" width="430" height="80" as="geometry" />
        </mxCell>
        
        <!-- Параметр levels -->
        <mxCell id="levels_title" value="⚙️ Параметр: уровни декомпозиции" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="300" width="250" height="20" as="geometry" />
        </mxCell>
        
        <mxCell id="levels_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="420" y="320" width="150" height="80" as="geometry" />
        </mxCell>
        
        <mxCell id="levels_text" value="levels = 4 (по умолчанию)&#xa;&#xa;Больше уровней:&#xa;• Лучшее разделение&#xa;• Меньше коэффициентов A" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="425" y="325" width="140" height="70" as="geometry" />
        </mxCell>
        
      </root>
