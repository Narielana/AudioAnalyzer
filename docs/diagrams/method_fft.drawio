<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2025-03-11T00:00:00.000Z" agent="Draw.io" version="22.1.0" type="device">
  <diagram id="fft-method" name="FFT - Преобразование Фурье">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Заголовок -->
        <mxCell id="title" value="FFT (Fast Fourier Transform)&#xa;Быстрое преобразование Фурье" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="700" height="50" as="geometry" />
        </mxCell>
        
        <!-- Секция: Идея метода -->
        <mxCell id="idea_title" value="💡 Идея метода (простыми словами)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="idea_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="500" height="130" as="geometry" />
        </mxCell>
        
        <mxCell id="idea_text" value="Любой звук можно представить как сумму&#xa;простых синусоид разных частот и амплитуд.&#xa;&#xa;FFT &quot;разбирает&quot; звук на эти синусоиды:&#xa;• Как призма разделяет свет на цвета радуги&#xa;• Каждая &quot;частота&quot; — это отдельная синусоида&#xa;&#xa;Это самый распространённый метод в аудио!" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="50" y="105" width="480" height="120" as="geometry" />
        </mxCell>
        
        <!-- Схема работы -->
        <mxCell id="scheme_title" value="⚙️ Как работает FFT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="300" height="30" as="geometry" />
        </mxCell>
        
        <!-- Вход -->
        <mxCell id="input" value="Входной&#xa;сигнал" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="80" height="50" as="geometry" />
        </mxCell>
        
        <!-- Окно -->
        <mxCell id="window" value="Окно&#xa;Ханна" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="150" y="300" width="80" height="50" as="geometry" />
        </mxCell>
        
        <!-- FFT -->
        <mxCell id="fft_core" value="rFFT&#xa;(вещественное&#xa;FFT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="260" y="295" width="90" height="60" as="geometry" />
        </mxCell>
        
        <!-- Спектр -->
        <mxCell id="spectrum" value="Комплексный&#xa;спектр&#xa;(амплитуда+фаза)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="380" y="290" width="100" height="70" as="geometry" />
        </mxCell>
        
        <!-- Отбор -->
        <mxCell id="selection" value="Отбор&#xa;коэффициентов&#xa;(energy/lowpass)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="380" y="380" width="100" height="60" as="geometry" />
        </mxCell>
        
        <!-- IFFT -->
        <mxCell id="ifft" value="irFFT&#xa;(обратное)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="260" y="385" width="90" height="50" as="geometry" />
        </mxCell>
        
        <!-- Выход -->
        <mxCell id="output" value="Восстановленный&#xa;сигнал" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="150" y="385" width="80" height="50" as="geometry" />
        </mxCell>
        
        <!-- MP3 -->
        <mxCell id="mp3" value="MP3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="385" width="80" height="50" as="geometry" />
        </mxCell>
        
        <!-- Стрелки -->
        <mxCell id="arr1" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="input" target="window">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr2" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="window" target="fft_core">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr3" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="fft_core" target="spectrum">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr4" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="spectrum" target="selection">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr5" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="selection" target="ifft">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr6" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="ifft" target="output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr7" style="endArrow=classic;html=1;strokeWidth=2" edge="1" parent="1" source="output" target="mp3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        
        <!-- Математика -->
        <mxCell id="math_title" value="📐 Математическая формула" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="math_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="500" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="math_text" value="X[k] = Σ x[n] · e^(-j·2π·k·n/N),  k = 0..N-1&#xa;&#xa;где:&#xa;• x[n] — входной сигнал, X[k] — спектр&#xa;• k — индекс частоты, N — размер окна" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=10;spacingTop=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="50" y="505" width="480" height="80" as="geometry" />
        </mxCell>
        
        <!-- Преимущества -->
        <mxCell id="pros_title" value="✅ Преимущества FFT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#0d652d" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="pros_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="600" y="130" width="450" height="160" as="geometry" />
        </mxCell>
        
        <mxCell id="pros_text" value="📊 Физический смысл:&#xa;   • Коэффициенты = реальные частоты&#xa;   • Понятная интерпретация спектра&#xa;&#xa;🔬 Универсальность:&#xa;   • Стандарт в аудио обработке&#xa;   • Используется в MP3, AAC, OGG&#xa;&#xa;📐 Точность:&#xa;   • Высокое спектральное разрешение&#xa;   • Хорошее разделение частот" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="610" y="135" width="430" height="150" as="geometry" />
        </mxCell>
        
        <!-- Недостатки -->
        <mxCell id="cons_title" value="⚠️ Недостатки FFT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="600" y="310" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="cons_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="600" y="340" width="450" height="140" as="geometry" />
        </mxCell>
        
        <mxCell id="cons_text" value="💻 Вычислительная сложность:&#xa;   • Требует комплексных умножений&#xa;   • Медленнее FWHT на простых процессорах&#xa;&#xa;🔢 Ограничения:&#xa;   • N = 2ⁿ для Cooley-Tukey&#xa;&#xa;📈 Спектральная утечка:&#xa;   • Требует оконных функций&#xa;   • Размытие частот при переходах" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="610" y="345" width="430" height="130" as="geometry" />
        </mxCell>
        
        <!-- Сравнение с FWHT -->
        <mxCell id="comp_title" value="⚖️ Сравнение FWHT vs FFT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="600" y="500" width="300" height="30" as="geometry" />
        </mxCell>
        
        <mxCell id="comp_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f0fe;strokeColor=#1a73e8" vertex="1" parent="1">
          <mxGeometry x="600" y="530" width="450" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="comp_text" value="                    FWHT          FFT&#xa;Операции:         + и −         × и ÷&#xa;Скорость:          быстрее       медленнее&#xa;Интерпретация:     sequency      частота&#xa;Применение:        спец.        стандарт" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacingLeft=10;spacingTop=10;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="610" y="535" width="430" height="90" as="geometry" />
        </mxCell>
        
        <!-- Визуализация спектра -->
        <mxCell id="vis_title" value="Визуализация спектра:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=1" vertex="1" parent="1">
